{
    "layer": "top",
    "position": "top",
    "reload_style_on_change": true,
    "modules-left": ["custom/notification","hyprland/workspaces","custom/pacman"],
    "modules-center": ["clock"],
    "modules-right": ["tray","group/expand","network","bluetooth","pulseaudio","battery"],

    "custom/notification": {
        "tooltip": false,
        "format": "ΌγΡ",
        "on-click": "swaync-client -t -sw",
        "escape": true
    },
    "hyprland/workspaces": {
        "format": "{icon}",
	"format-icons": {
            "active": "ΎΕΣ",
	    "default": "ΎΕΣ",
	    "empty": "ΎΕΣ"
	},
	"persistent-workspaces": {
            "*": [ 1,2,3,4,5 ]
	}
    },
    "custom/pacman": {
        "format": "≤░Ζλ {}",
        "interval": 900,   
	"exec": "bash -c 'echo $(( $(checkupdates 2>/dev/null | wc -l) + $(yay -Qua 2>/dev/null | wc -l) ))'",
        "exec-if": "exit 0",
        "on-click": "ghostty -e sh -c 'yay -Syu; echo Done - Press enter to exit; read'; pkill -SIGRTMIN+8 waybar",
        "signal": 8,
        "tooltip": false,
    },

    "clock": {
        "format": "{:L%a %d %b έΑλ %H:%M}",
	"tooltip-format": "<span size='11pt' font='CommitMono Nerd Font'>{calendar}</span>",
	"calendar": {
	    "mode": "month",
	    "weeks-pos": "right",
            "format": {
	        "months": "<span color='#689d6a'><b>{}</b></span>",
		"days": "<span color='#ebdbb2'>{}</span>",
		"weeks": "<span color='#458588'><b>W{}</b></span>",
		"weekdays": "<span color='#d79921'><b>{}</b></span>",
	        "today": "<span color='#d65d0e'><b><u>{}</u></b></span>" 
	    }
	}
    },

    "tray": {
        "icon-size": 14,
	"spacing": 10
    },
    "custom/expand": {
        "format": "ΎΕΕ",
        "tooltip": false
    },
    "custom/endpoint": {
        "format": "έΦΓ",
	"tooltip": false
    },
    "group/expand": {
        "orientation": "horizontal",
	"drawer": {
	    "transition-duration": 600,
	    "transition-to-left": true,
	    "click-to-reveal": true
	},
	"modules": ["custom/expand","backlight","custom/kbd_backlight", "custom/endpoint"],
    },
    "backlight": {
        "device": "intel_backlight",
        "format": "≤░Δι",
	"tooltip-format": "{percent}%",
	"on-scroll-down": "swayosd-client --brightness +2",
	"on-scroll-up": "swayosd-client --brightness -2"
    },
    "custom/kbd_backlight": {
        "on-click": "sh -c 'c=$(brightnessctl -d tpacpi::kbd_backlight get); n=$(( (c + 1) % 3 )); brightnessctl -d tpacpi::kbd_backlight set $n'",
        "format": "≤░ΝΝ",
        "tooltip": false
    },

    "network": {
        "format-icons": ["≤░νψ", "≤░νθ", "≤░νλ", "≤░νξ", "≤░νρ"],
        "format": "{icon}",
        "format-wifi": "{icon}",
        "format-ethernet": "≤░ΑΓ",
        "format-disconnected": "≤░νχ",
        "tooltip-format-wifi": "{essid} ({frequency} GHz)\nέΘμ{bandwidthDownBytes}  έΘκ{bandwidthUpBytes}",
        "tooltip-format-ethernet": "έΘμ{bandwidthDownBytes}  έΘκ{bandwidthUpBytes}",
        "tooltip-format-disconnected": "Disconnected",
        "interval": 3,
        "spacing": 1,
        "on-click": "ghostty -e nmtui"
    },
    "bluetooth": {
        "format": "ΎΛΦ",
        "format-disabled": "≤░Γ▓",
        "format-connected": "≤░Γ▒",
        "format-no-controller": "",
        "tooltip-format": "Devices connected: {num_connections}",
	"on-click": "blueman-manager"
    },
    "pulseaudio": {
        "format": "{icon}",
        "tooltip-format": "Playing at {volume}%",
	"on-scroll-down": "swayosd-client --output-volume 2",
	"on-scroll-up": "swayosd-client --output-volume -2",
        "format-muted": "Ό╗ρ",
        "format-icons": {
            "default": ["ΎΑο", "ΎΑπ", "ΎΑρ"]
        },
	"on-click": "swayosd-client --output-volume mute-toggle",
        "on-click-right": "pavucontrol"
    },
    "battery": {
        "format": "{capacity}% {icon}",
        "format-discharging": "{icon}",
        "format-charging": "{icon}",
        "format-plugged": "ΎΘο",
        "format-icons": {
            "charging": ["≤░λε", "≤░ΓΗ", "≤░ΓΘ", "≤░ΓΙ", "≤░λζ", "≤░ΓΚ", "≤░λη", "≤░ΓΛ", "≤░ΓΜ", "≤░ΓΖ"],
            "default": ["≤░Β║", "≤░Β╗", "≤░Β╝", "≤░Β╜", "≤░Β╛", "≤░Β┐", "≤░ΓΑ", "≤░ΓΒ", "≤░ΓΓ", "≤░Β╣"]
        },
        "format-full": "≤░ΓΖ",
        "tooltip-format-discharging": "{power:>1.0f}WέΗΥ {capacity}%",
        "tooltip-format-charging": "{power:>1.0f}WέΗΣ {capacity}%",
        "interval": 5,
        "states": {
            "warning": 40,
            "critical": 20
        }
    }
}
